      "unrelated_decision_results_preserve_grant": true,
      "invalidated_only_by": ["material_target_drift", "material_scope_drift", "material_payload_drift", "material_tool_drift", "material_consequence_drift", "explicit_action_specific_owner_amendment", "explicit_action_specific_owner_revocation", "explicit_action_specific_owner_cancellation"]
