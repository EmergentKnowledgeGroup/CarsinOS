{
  "schema_metadata": {
    "contract_id": "carsinos.execass.contract",
    "contract_version": "v1",
    "schema_version": "1.1.0",
    "locked_spec_version": "1.1",
    "api_prefix": "/api/v1/execass",
    "additional_properties": false
  },
  "lifecycle": {
    "phases": ["accepted", "planning", "in_motion", "waiting_for_user", "waiting_external", "recovering", "completed", "partially_completed", "failed"],
    "terminal_phases": ["completed", "partially_completed", "failed"],
    "branch_states": ["runnable", "executing", "waiting", "uncertain", "terminal"],
    "precedence": [
      {"rank": 1, "condition": "valid_completion_assessment", "selects": ["completed", "partially_completed", "failed"]},
      {"rank": 2, "condition": "before_actionable_planning", "selects": ["accepted", "planning"]},
      {"rank": 3, "condition": "authorized_ordinary_branch_runnable_or_executing", "selects": ["in_motion"]},
      {"rank": 4, "condition": "bounded_recovery_runnable_or_executing", "selects": ["recovering"]},
      {"rank": 5, "condition": "actionable_human_attention", "selects": ["waiting_for_user"]},
      {"rank": 6, "condition": "external_party_system_or_time_dependency", "selects": ["waiting_external"]},
      {"rank": 7, "condition": "no_autonomous_human_or_external_path", "selects": ["completion_assessor_required"]}
    ]
  },
  "run_control": {
    "states": ["running", "stop_requested", "stopped"],
    "stopped_is_orthogonal": true,
    "stop_requested_is_draining": true,
    "stopped_preconditions": ["new_claims_blocked", "active_claims_fenced", "safe_boundary_work_ended_or_unresolved_external_effect_recorded"],
    "resume_requires": ["fresh_plan_snapshot", "fresh_policy_snapshot"]
  },
  "attention": {
    "variants": ["confirmation", "clarification", "reply", "recovery_choice", "runtime_paused"],
    "required_fields": ["subject", "decision_kind", "reason", "recommendation", "alternatives_or_actions", "assurance_required", "deadline_reminder_state", "decision_revision", "authoritative_deep_link"],
    "subject_kinds": ["delegation", "runtime_host"],
    "decision_kind_mapping": {
      "clarification": "clarification",
      "dangerous_action_confirmation": "confirmation",
      "owner_configured_checkpoint": "confirmation",
      "recovery_choice": "recovery_choice",
      "duplicate_risk_retry": "confirmation",
      "stop": "confirmation",
      "policy_change": "confirmation"
    },
    "projection": "needs_you",
    "is_phase_synonym": false
  },
  "owner_authority": {
    "topology": "one_authenticated_owner_one_execass_one_carsinos",
    "exact_authenticated_instruction_authorizes": ["ordinary_exact_action", "operational_policy_amendment"],
    "authority_evaluation_order": ["stop_revocation_superseding_amendment_exact_action_and_technical_validity", "current_exact_instruction_or_confirmed_amendment", "saved_exact_versioned_envelope", "operational_policy_for_derived_or_unattended_work", "nonhuman_content_is_evidence_only"],
