{
  "name": "mission-control",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "dev": "vite --host --port 1420",
    "build": "tsc -b && vite build",
    "typecheck": "tsc -b --pretty false",
    "lint": "eslint .",
    "test:unit": "vitest run",
    "test:e2e:core": "playwright test --config=playwright.config.ts --grep \"@core\"",
    "test:e2e:full": "playwright test --config=playwright.config.ts",
    "test:e2e:tauri-smoke": "node ../../scripts/mission_control_e2e_placeholder.mjs tauri-smoke",
    "quality:acceptance:p1": "python3 ../../scripts/mission_control_phase_acceptance_check.py --phase P1",
    "quality:acceptance:p2": "python3 ../../scripts/mission_control_phase_acceptance_check.py --phase P2",
    "quality:acceptance:p3": "python3 ../../scripts/mission_control_phase_acceptance_check.py --phase P3",
    "quality:gate": "python3 ../../scripts/mission_control_quality_gate.py --profile=pr",
    "quality:gate:pr": "python3 ../../scripts/mission_control_quality_gate.py --profile=pr",
    "quality:gate:release": "python3 ../../scripts/mission_control_quality_gate.py --profile=release",
    "preview": "vite preview --host --port 1420",
    "tauri": "tauri",
    "tauri:dev": "tauri dev",
    "tauri:build": "tauri build"
  },
  "dependencies": {
    "@dnd-kit/core": "^6.3.1",
    "@dnd-kit/sortable": "^10.0.0",
    "@dnd-kit/utilities": "^3.2.2",
    "@tanstack/react-virtual": "^3.13.12",
    "@tauri-apps/api": "^2.8.0",
    "clsx": "^2.1.1",
    "lucide-react": "^0.575.0",
    "react": "^19.2.0",
    "react-dom": "^19.2.0",
    "react-grid-layout": "^1.5.2",
    "react-resizable": "^3.0.5"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.1",
    "@playwright/test": "^1.58.2",
    "@tauri-apps/cli": "^2.9.1",
    "@types/node": "^24.10.1",
    "@types/react": "^19.2.7",
    "@types/react-dom": "^19.2.3",
    "@types/react-grid-layout": "^1.3.6",
    "@vitejs/plugin-react": "^5.1.1",
    "eslint": "^9.39.1",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-react-refresh": "^0.4.24",
    "globals": "^16.5.0",
    "jsdom": "^27.1.0",
    "typescript": "~5.9.3",
    "typescript-eslint": "^8.48.0",
    "vite": "^7.3.1",
    "vitest": "^4.0.0",
    "ws": "^8.19.0"
  }
}
