{
  "$schema": "../node_modules/@tauri-apps/cli/config.schema.json",
  "productName": "CarsinOS Mission Control",
  "version": "0.1.0",
  "identifier": "io.carsinos.missioncontrol",
  "build": {
    "frontendDist": "../dist",
    "devUrl": "http://localhost:1420",
    "beforeDevCommand": "npm run dev -- --host --port 1420 --strictPort",
    "beforeBuildCommand": "npm run build"
  },
  "app": {
    "windows": [
      {
        "title": "CarsinOS Mission Control",
        "width": 1500,
        "height": 980,
        "minWidth": 1200,
        "minHeight": 760,
        "resizable": true,
        "fullscreen": false
      }
    ],
    "security": {
      "csp": "default-src 'self' tauri:; connect-src 'self' http://127.0.0.1:* http://localhost:* ws://127.0.0.1:* ws://localhost:* https://*.carsinos.io wss://*.carsinos.io; img-src 'self' asset: data: blob:; style-src 'self'; font-src 'self' data:; script-src 'self';"
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "macOS": {
      "entitlements": "Entitlements.plist",
      "minimumSystemVersion": "15.0"
    }
  }
}
